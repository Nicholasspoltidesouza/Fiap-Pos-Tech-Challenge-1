### Terraform ###
# Local .terraform directories (providers, modules)
**/.terraform/*
# State files (may contain sensitive data)
*.tfstate
*.tfstate.*
# Crash log files
crash.log
crash.*.log
# Variable files that may contain secrets (keep *.tfvars.example)
*.tfvars
*.tfvars.json
!*.tfvars.example
# Override files (local-only)
override.tf
override.tf.json
*_override.tf
*_override.tf.json
# CLI configuration files
.terraformrc
terraform.rc
# Plan output files
*.tfplan

